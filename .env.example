# Copy to .env and fill in your keys. Never commit the real .env.

# Required — https://console.groq.com/
GROQ_API_KEY="your-groq-key"

# Optional — per-task Groq models (defaults shown). Each model has its own
# rate-limit quota, so spreading tasks across models spreads the traffic.
MODEL_CLASSIFIER="llama-3.1-8b-instant"
MODEL_GREETING="llama-3.1-8b-instant"
MODEL_SYMPTOM="llama-3.3-70b-versatile"
MODEL_GENERAL="openai/gpt-oss-120b"

# Optional — RAG embeddings (defaults shown)
EMBEDDING_BACKEND="auto"              # auto | ollama | fastembed
EMBEDDING_MODEL="nomic-embed-text"    # Ollama model
FASTEMBED_MODEL="BAAI/bge-small-en-v1.5"

# Optional — LangSmith tracing (https://smith.langchain.com/)
LANGCHAIN_API_KEY="your-langsmith-key"
LANGSMITH_TRACING="true"
LANGSMITH_PROJECT="MedAssist"
